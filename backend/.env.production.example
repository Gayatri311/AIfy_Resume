# ─── Alfy Resume API — production (private beta) ───
# Copy values into Railway / Fly / Render env vars. Do NOT commit real secrets.

# Database (use provider-managed Postgres — not localhost)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/alfy_resume
DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST:5432/alfy_resume

# Redis (optional for beta — API uses in-process BackgroundTasks by default)
REDIS_URL=redis://HOST:6379/0

# LLM (required for full pipeline)
GOOGLE_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# App
DEBUG=false
CORS_ORIGINS=https://YOUR-APP.vercel.app
FRONTEND_URL=https://YOUR-APP.vercel.app
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10

# Leave false unless Celery worker is deployed with USE_CELERY=true
USE_CELERY=false

# Stripe — optional for private beta (billing routes not required for core flow)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
