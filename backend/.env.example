# Database
DATABASE_URL=postgresql+asyncpg://alfy:alfy@localhost:5432/alfy_resume
DATABASE_URL_SYNC=postgresql://alfy:alfy@localhost:5432/alfy_resume

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# LLM (recommended — enables smart role-aware enhancements; falls back to rules if empty)
# Get a Gemini key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# Optional alternates
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Supabase Storage (optional)
SUPABASE_URL=
SUPABASE_KEY=

# App
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10
DEBUG=false

# Stripe (required for production billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
